<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/messageRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/selectionCheckStart"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:alpha="0"
            android:visibility="gone"
            android:background="@drawable/tg_select_indicator" />

        <View
            android:id="@+id/avatarStub"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/tg_avatar_circle" />

        <FrameLayout
            android:id="@+id/bubbleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/tg_bubble_outgoing"
            android:minWidth="60dp">

            <LinearLayout
                android:id="@+id/bubbleContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/senderText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:text="Sender"
                    android:textColor="#84581E"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/messageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="280dp"
                    android:textColor="#121212"
                    android:textSize="17sp" />

                <LinearLayout
                    android:id="@+id/timeRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/timeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:43"
                        android:textColor="#00B1BA"
                        android:textSize="13sp" />

                    <ImageView
                        android:id="@+id/statusIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/icon_16_receive"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/selectionCheckEnd"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:alpha="0"
            android:visibility="gone"
            android:background="@drawable/tg_select_indicator" />
    </LinearLayout>

    <TextView
        android:id="@+id/detailText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0"
        android:textColor="#666666"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/typeToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:alpha="0.8"
        android:text="切换类型"
        android:textColor="#4A6CF7"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>

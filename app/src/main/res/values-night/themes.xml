<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.StudyDemo"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor"
            tools:targetApi="l">?attr/colorPrimaryVariant
        </item>
        <!-- Disable window ActionBar, we use Toolbar via BaseActivity -->
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <!-- Customize your theme here. -->

        <!-- 全局 MaterialButton 默认样式接入（夜间与日间统一走主题色） -->
        <item name="materialButtonStyle">@style/Widget.StudyDemo.MaterialButton</item>
        <!-- 可选：Outlined 样式接入 -->
        <item name="materialButtonOutlinedStyle">@style/Widget.StudyDemo.MaterialButton.Outlined</item>

    </style>
</resources>
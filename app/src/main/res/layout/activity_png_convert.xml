<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".module_media.PngConvertActivity">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnScanAndConvert"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:text="扫描并转换为PNG"
        android:textAllCaps="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnScanAndConvertJpg"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:text="扫描并转换为JPG（质量100）"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/btnScanAndConvert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        />

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/btnScanAndConvertJpg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"
        >
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="扫描结果与转换进度会显示在这里"
            android:textSize="14sp"
            />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>